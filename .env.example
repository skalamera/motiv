# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway — key from Vercel dashboard / AI Gateway
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Google Generative AI — https://aistudio.google.com/apikey (optional if AI_GATEWAY_API_KEY is set)
# Strongly recommended for `npm run index-car-library` on large trees (Gateway free tier rate-limits bulk embeds).
# Chat + query embeddings can use either this key or AI Gateway.
# Required for AI-generated car hero photos (Settings → add vehicle without a photo); uses gemini-2.5-flash-image.
GOOGLE_GENERATIVE_AI_API_KEY=

# News — https://newsapi.org (optional; News page shows setup message if missing)
NEWS_API_KEY=

# YouTube Data API v3 — personalized Videos page search (optional)
YOUTUBE_API_KEY=AIzaSyA706qSDirk0HZeQUzf3Lrs17DKzPF6f4M

# Google Maps JavaScript API — Local Drives / dashboard map (optional)
# Create a key in Google Cloud, enable Maps JavaScript API + billing, and add HTTP referrer
# restrictions for your Vercel URL and http://localhost:3000/*
GOOGLE_MAPS_API=
